{
  "manifest_version": 3,
  "name": "AI Prompt Workspace",
  "version": "1.0",
  "icons": {
    "16": "meta/favicon-16x16.png",
    "32": "meta/favicon-32x32.png"
  },
  "description": "AI Prompt Workspace",
  "permissions": [
    "storage",
    "sidePanel",
    "contextMenus"
  ],
  "action": {
    "default_title": "Toggle Workspace",
    "default_icon": {
      "16": "meta/favicon-16x16.png",
      "32": "meta/favicon-32x32.png"
    }
  },
  "background": {
    "service_worker": "assets/background.js",
    "type": "module"
  },
  "side_panel": {
    "default_path": "side_panel.html"
  },
  "host_permissions": [
    "<all_urls>"
  ]
}