{
  "manifest_version": 3,
  "name": "Status Notepad Sidebar",
  "version": "1.0",
  "description": "A lightweight Chrome extension for tracking task statuses and event handling in a side panel notepad.",
  "permissions": ["storage", "sidePanel", "contextMenus"],
  "action": {
    "default_title": "Toggle Notes"
  },
  "background": {
    "service_worker": "assets/background.js"
  },
  "side_panel": {
    "default_path": "index.html"
  },
  "host_permissions": ["<all_urls>"]
}
